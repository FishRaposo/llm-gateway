    "zod": "^3.23.8",
    "dotenv": "^16.4.5",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.3",
    "tsx": "^4.16.2",
    "vitest": "^2.0.3",
    "@vitest/coverage-v8": "^2.0.3",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/better-sqlite3": "^7.6.8",
    "@types/js-yaml": "^4.0.9",
    "@types/uuid": "^10.0.0",
    "@types/node": "^20.14.10"
