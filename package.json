{
  "name": "llm-gateway",
  "version": "1.0.0",
  "description": "A lightweight LLM operations gateway for routing, cost control, fallback, and auditability",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^5.2.1",
    "cors": "^2.8.5",
    "ioredis": "^5.11.0",
    "better-sqlite3": "^12.10.0",
    "js-yaml": "^4.1.0",
    "zod": "^4.4.3",
    "dotenv": "^17.4.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "tsx": "^4.22.3",
    "vitest": "^4.1.7",
    "@vitest/coverage-v8": "^2.0.3",
    "@types/express": "^5.0.6",
    "@types/cors": "^2.8.17",
    "@types/better-sqlite3": "^7.6.8",
    "@types/js-yaml": "^4.0.9",
    "@types/uuid": "^11.0.0",
    "@types/node": "^25.9.1"
